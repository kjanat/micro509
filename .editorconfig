root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2
tab_width = 2
max_line_length = 100

[*.md]
max_line_length = 80
trim_trailing_whitespace = false
indent_size =
indent_style =

[*.{yml,yaml}]
max_line_length = 160
indent_style =
indent_size =
