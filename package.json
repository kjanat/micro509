{
	"name": "micro509",
	"version": "0.1.0",
	"description": "Small, typed X.509 builders for modern TypeScript",
	"keywords": [
		"x509",
		"certificate",
		"csr",
		"pem",
		"der",
		"jwk"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/ts-x509.git"
	},
	"license": "MIT",
	"type": "module",
	"imports": {
		"#micro509": "./src/index.ts",
		"#micro509/*": "./src/*"
	},
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown --no-attw --no-publint --no-unused --no-report",
		"build": "tsdown",
		"fmt": "dprint fmt",
		"lint": "biome lint",
		"test": "AGENT=1 bun test --coverage",
		"typecheck": "tsgo"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"@typescript/native-preview": "^7.0.0-dev.20260311.1",
		"dprint": "^0.52.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.2",
		"typescript": "^6.0.1-rc",
		"unplugin-unused": "^0.5.7"
	},
	"packageManager": "bun@1.3.10",
	"devEngines": {
		"packageManager": [
			{
				"name": "bun",
				"onFail": "download"
			},
			{
				"name": "npm",
				"version": ">=11"
			}
		],
		"runtime": [
			{
				"name": "node",
				"version": ">=24"
			},
			{
				"name": "bun",
				"version": ">=1.3"
			},
			{
				"name": "deno"
			}
		]
	},
	"volta": {
		"node": "25.8.0",
		"npm": "11.11.0"
	}
}
