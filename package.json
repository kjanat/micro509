{
	"name": "micro509",
	"version": "0.1.0",
	"description": "Small, typed X.509 builders for modern TypeScript",
	"keywords": [
		"x509",
		"certificate",
		"csr",
		"pem",
		"der",
		"jwk"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "bun run build",
		"build": "tsc -p tsconfig.build.json",
		"fmt": "dprint fmt",
		"lint:biome": "bunx @biomejs/biome lint {src,test}",
		"test": "AGENT=1 bun test --coverage",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.3.10",
		"@typescript/native-preview": "^7.0.0-dev.20260311.1",
		"dprint": "^0.52.0",
		"typescript": "^6.0.1-rc"
	},
	"packageManager": "bun@1.3.10",
	"devEngines": {
		"packageManager": [
			{
				"name": "bun",
				"onFail": "download"
			}
		],
		"runtime": [
			{
				"name": "node"
			},
			{
				"name": "bun"
			},
			{
				"name": "deno"
			}
		]
	},
	"volta": {
		"node": "25.8.0",
		"npm": "11.11.0"
	}
}
