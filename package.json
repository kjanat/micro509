{
	"name": "micro509",
	"version": "0.1.0",
	"description": "Small, typed X.509 builders for modern TypeScript",
	"keywords": [
		"x509",
		"certificate",
		"csr",
		"pem",
		"der",
		"jwk"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/ts-x509.git"
	},
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"imports": {
		"#micro509": "./src/index.ts",
		"#micro509/*": "./src/*",
		"#micro509/internal/*": "./src/internal/*"
	},
	"exports": {
		".": "./dist/index.js",
		"./keys": "./dist/keys.js",
		"./pem": "./dist/pem.js",
		"./pkcs": "./dist/pkcs.js",
		"./result": "./dist/result.js",
		"./revocation": "./dist/revocation.js",
		"./verify": "./dist/verify.js",
		"./x509": "./dist/x509.js",
		"./package.json": "./package.json"
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"bd": "tsdown --no-attw --no-publint --no-unused --no-report",
		"build": "tsdown",
		"docs:build": "rm -rf ./docs/deno 2>/dev/null; deno doc --html --output=./docs/deno --name=micro509 src/**/index.ts",
		"docs:lint": "rm -rf ./docs/deno 2>/dev/null; deno doc --html --output=./docs/deno --name=micro509 --lint src/**/index.ts",
		"fmt": "dprint fmt",
		"lint": "bun lint:biome",
		"lint:biome": "biome lint",
		"lint:deno": "deno lint --rules-exclude=no-node-globals,require-await,no-unused-vars src",
		"test": "AGENT=1 bun test --coverage",
		"test:differential": "bun test test/differential.test.ts",
		"test:pkits": "bun test test/pkits.test.ts",
		"typecheck": "tsgo --noEmit -p tsconfig.src.json && tsgo --noEmit -p tsconfig.other.json",
		"typecheck:tsc": "tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.other.json"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"@typescript/native-preview": "^7.0.0-dev.20260311.1",
		"dprint": "^0.52.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.2",
		"typescript": "^6.0.1-rc",
		"unplugin-unused": "^0.5.7"
	},
	"packageManager": "bun@1.3.10",
	"devEngines": {
		"packageManager": [
			{
				"name": "bun",
				"onFail": "download"
			},
			{
				"name": "npm",
				"version": ">=11"
			}
		],
		"runtime": [
			{
				"name": "node",
				"version": ">=24"
			},
			{
				"name": "bun",
				"version": ">=1.3"
			},
			{
				"name": "deno"
			}
		]
	},
	"volta": {
		"node": "25.8.0",
		"npm": "11.11.0"
	}
}
