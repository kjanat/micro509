{
  "extends": [
    "@tsconfig/node24/tsconfig.json",
    "@vue/tsconfig",
    "@vue/tsconfig/tsconfig.dom.json"
  ],
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "paths": {
      "#/*": ["./*"],
      "#/components/*": ["./theme/components/*"],
    }
  },
  "exclude": ["./dist/", "./cache/"]
}
