{
	"$schema": "https://opencode.ai/config.json",
	"model": "anthropic/claude-opus-4-6",
	"small_model": "anthropic/claude-sonnet-4-6",
	"autoupdate": true,
	"formatter": {
		"dprint": {
			"command": ["dprint", "fmt", "$FILE"],
			"extensions": [
				".sh",
				".bash",
				".toml",
				".svg",
				".json",
				".jsonc",
				".md",
				".ts",
				".mts",
				".cts",
				".js",
				".mjs",
				".cjs",
				".yml",
				".yaml",
				".py",
			],
		},
	},
}
