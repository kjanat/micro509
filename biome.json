{
	"$schema": "https://biomejs.dev/schemas/latest/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master"
	},
	"files": {
		"includes": ["**", "!!**/dist", "!!**/*.svg"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"domains": {
			"project": "recommended",
			"test": "recommended"
		},
		"rules": {
			"complexity": {
				"useLiteralKeys": "off",
				"recommended": true
			},
			"correctness": { "recommended": true },
			"performance": { "recommended": true },
			"nursery": { "recommended": true },
			"security": { "recommended": true },
			"style": { "recommended": true },
			"suspicious": { "recommended": true }
		}
	},
	"javascript": {
		"formatter": { "quoteStyle": "single" }
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": { "organizeImports": "off" }
		}
	},
	"overrides": [{
		"includes": ["**/*.jsonc", "!biome.jsonc"],
		"json": { "formatter": { "trailingCommas": "all" } }
	}, {
		"includes": ["**/site"],
		"formatter": {
			"lineWidth": 60
		}
	}, {
		"includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
		"linter": {
			"rules": {
				"style": { "useConst": "off", "useImportType": "off" },
				"correctness": { "noUnusedVariables": "off", "noUnusedImports": "off" }
			}
		}
	}, {
		"includes": ["site/**"],
		"formatter": { "indentStyle": "space" },
		"javascript": { "formatter": { "indentStyle": "tab" } },
		"assist": { "enabled": false }
	}]
}
