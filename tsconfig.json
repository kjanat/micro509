{
	"compilerOptions": {
		"target": "ES2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": [
			"ES2023",
			"DOM"
		],
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"declaration": true,
		"sourceMap": true,
		"outDir": "dist",
		"types": [
			"node",
			"vitest/globals"
		],
		"skipLibCheck": true
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	]
}
